#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MODULE="$(cd "$SCRIPT_DIR/.." && pwd)"
WORKSPACE_ROOT="$(cd "$MODULE/../.." && pwd)"
if [[ -f "$WORKSPACE_ROOT/lib/dreambot-client.jar" || -d "$WORKSPACE_ROOT/data/DreamBot" ]]; then
  DEFAULT_ROOT="$WORKSPACE_ROOT"
else
  DEFAULT_ROOT="$MODULE"
fi
ROOT="${DREAMBOT_ROOT:-$DEFAULT_ROOT}"
SRC="$MODULE/src"
BUILD="$MODULE/build"
CLASSES="$BUILD/classes"
SOURCES="$BUILD/sources.txt"
MANIFEST="$BUILD/manifest.mf"
DEPS="$BUILD/deps"
OUT_DIR="${DREAMBOT_MCP_OUT_DIR:-$ROOT/dist}"
OUT_JAR="$OUT_DIR/dreambot-mcp.jar"
API_JAR="${DREAMBOT_API_JAR:-$ROOT/lib/dreambot-client.jar}"
JANINO_VERSION="3.1.12"
JANINO_JAR="${DREAMBOT_MCP_JANINO_JAR:-$DEPS/janino-$JANINO_VERSION.jar}"
COMMONS_COMPILER_JAR="${DREAMBOT_MCP_COMMONS_COMPILER_JAR:-$DEPS/commons-compiler-$JANINO_VERSION.jar}"
JANINO_SHA256="5699878c31e71c9a94cf472f95a2dad52ca7b0449c099276b8bd7e992a43595b"
COMMONS_COMPILER_SHA256="17ea25d860225f4b59d0a512b4995f2e4711bdae5e15736cbcd5f6ce4dda8f7c"

if [[ ! -f "$API_JAR" ]]; then
  echo "Missing DreamBot API jar: $API_JAR" >&2
  exit 1
fi

rm -rf "$BUILD"
mkdir -p "$CLASSES" "$OUT_DIR" "$DEPS"

download_dep() {
  local url="$1"
  local target="$2"
  if [[ -f "$target" ]]; then
    return
  fi
  curl -fsSL "$url" -o "$target"
}

verify_dep() {
  local expected="$1"
  local target="$2"
  local actual
  actual="$(sha256sum "$target" | awk '{print $1}')"
  if [[ "$actual" != "$expected" ]]; then
    echo "Checksum mismatch for $target" >&2
    echo "expected $expected" >&2
    echo "actual   $actual" >&2
    exit 1
  fi
}

download_dep \
  "https://repo1.maven.org/maven2/org/codehaus/janino/janino/$JANINO_VERSION/janino-$JANINO_VERSION.jar" \
  "$JANINO_JAR"
download_dep \
  "https://repo1.maven.org/maven2/org/codehaus/janino/commons-compiler/$JANINO_VERSION/commons-compiler-$JANINO_VERSION.jar" \
  "$COMMONS_COMPILER_JAR"
verify_dep "$JANINO_SHA256" "$JANINO_JAR"
verify_dep "$COMMONS_COMPILER_SHA256" "$COMMONS_COMPILER_JAR"

find "$SRC" -name '*.java' | sort > "$SOURCES"

javac --release 11 -encoding UTF-8 -cp "$API_JAR:$JANINO_JAR:$COMMONS_COMPILER_JAR" -d "$CLASSES" @"$SOURCES"

(
  cd "$CLASSES"
  jar xf "$COMMONS_COMPILER_JAR"
  jar xf "$JANINO_JAR"
  rm -f META-INF/MANIFEST.MF META-INF/*.SF META-INF/*.DSA META-INF/*.RSA
)

cat > "$MANIFEST" <<'EOF'
Manifest-Version: 1.0
Main-Class: com.pernasua.dreambot.mcp.Main
Implementation-Title: DreamBot MCP
Implementation-Version: 2.4.1
EOF

jar --create \
  --file "$OUT_JAR" \
  --manifest "$MANIFEST" \
  --date=2026-01-01T00:00:00Z \
  -C "$CLASSES" .

echo "Built $OUT_JAR"
